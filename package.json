{
  "name": "@playbox-ai/playable-kit",
  "version": "0.3.4",
  "description": "Playable-ad packaging, validation, checks and preview SDK for the Playbox platform",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./networks": {
      "import": {
        "types": "./dist/networks.d.ts",
        "default": "./dist/networks.js"
      },
      "require": {
        "types": "./dist/networks.d.cts",
        "default": "./dist/networks.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "networks": [
        "./dist/networks.d.cts"
      ],
      "types": [
        "./dist/types.d.cts"
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "codegen": "node scripts/embed-jszip.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "playbox",
    "playable-ads",
    "packaging",
    "validation",
    "html5-games"
  ],
  "author": "Playbox Platform <hello@plbx.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/playbox-org/playable-kit.git"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "clean-css": "^5.3.0",
    "jszip": "^3.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/clean-css": "^4.2.11",
    "@types/node": "^20.14.0",
    "eslint": "^9.39.1",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "THIRD-PARTY-NOTICES.md"
  ]
}
